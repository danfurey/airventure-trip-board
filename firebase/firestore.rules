rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Every visitor has the same board permissions. Anonymous Authentication is
    // used silently only to prevent unauthenticated internet writes.
    match /trips/{tripId}/votes/{voteId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.trip_id == tripId
        && request.resource.data.user_id == 'shared-board';
      allow delete: if signedIn();
    }

    match /trips/{tripId}/groupChoices/{eventId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.trip_id == tripId
        && request.resource.data.event_id == eventId;
      allow delete: if signedIn();
    }
  }
}
